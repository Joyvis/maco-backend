{
  "name": "maco-backend",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "forwardPorts": [4000, 5432],
  "portsAttributes": {
    "4000": { "label": "NestJS (host)", "onAutoForward": "notify" },
    "5432": { "label": "Postgres", "onAutoForward": "silent" }
  },
  "remoteUser": "node",
  "initializeCommand": "cp -n .env .devcontainer/.env 2>/dev/null || true",
  "postCreateCommand": "sudo chown -R node:node /workspace/node_modules && sudo corepack enable && sudo corepack prepare pnpm@10.33.2 --activate && pnpm install",
  "postStartCommand": "pnpm run start",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "firsttris.vscode-jest-runner",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  }
}
