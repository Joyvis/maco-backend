# Database (individual connection params — used by MikroORM)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=maco
DATABASE_USER=maco
DATABASE_PASSWORD=maco

# MikroORM
MIKRO_ORM_DEBUG=false

# Legacy (devcontainer uses this via DATABASE_URL)
DATABASE_URL=postgresql://maco:maco@db:5432/maco

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# App
APP_PORT=3000

# CORS (comma-separated origins; defaults to http://localhost:3000 if unset)
CORS_ORIGINS=http://localhost:3000

# Payments
# PAYMENT_PROVIDER=mock is forbidden in production — main.ts crashes at startup if set.
PAYMENT_PROVIDER=mock                # mock | stone
PAYMENT_EXPIRATION_MINUTES=15
FRONTEND_URL=http://localhost:3000   # used by mock provider to compose the checkout URL
# Stone (only required when PAYMENT_PROVIDER=stone — left commented today)
# STONE_API_BASE_URL=https://sandbox-api.openbank.stone.com.br
# STONE_API_KEY=
# STONE_ACCOUNT_ID=
# STONE_WEBHOOK_SECRET=
