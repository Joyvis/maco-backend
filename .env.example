# Database (individual connection params — used by MikroORM)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=maco
DATABASE_USER=maco
DATABASE_PASSWORD=maco

# MikroORM
MIKRO_ORM_DEBUG=false

# Legacy (devcontainer uses this via DATABASE_URL)
DATABASE_URL=postgresql://maco:maco@db:5432/maco

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# App
APP_PORT=3000
